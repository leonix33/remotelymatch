{
  "manifest_version": 3,
  "name": "RemoteMatch Queue",
  "version": "1.1.0",
  "description": "Send job pages to RemoteMatch (LinkedIn, Wellfound, Indeed, and more)",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://remotematch.onrender.com/*",
    "https://remotematch.app/*",
    "https://www.remotematch.app/*",
    "http://localhost:5100/*",
    "http://localhost:5173/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to RemoteMatch"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://remotematch.onrender.com/*",
        "https://remotematch.app/*",
        "https://www.remotematch.app/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["setup-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.svg"
  }
}
