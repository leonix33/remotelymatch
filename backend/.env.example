PORT=5100
NODE_ENV=development
MONGODB_URI=
# With Docker Compose Mongo (npm run mongo:up) — port 27018 if 27017 is taken:
# MONGODB_URI=mongodb://127.0.0.1:27018/remotelymatch
# Or use an existing local Mongo on 27017:
# MONGODB_URI=mongodb://127.0.0.1:27017/remotelymatch
JWT_ACCESS_SECRET=change_this_to_a_long_random_value
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional secrets provider (recommended for production — open source)
# SECRETS_PROVIDER=hashicorp-vault
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=
# VAULT_MOUNT=secret
# VAULT_SECRET_PATH=remotelymatch
# Populate Vault: ./scripts/push-secrets-to-vault.sh
# Enable on Render: ./scripts/configure-hashicorp-vault-render.sh
# Store all keys in one KV object at secret/data/remotelymatch (OPENAI_API_KEY, APOLLO_API_KEY, …)
# Or use per-key paths: VAULT_OPENAI_API_KEY_PATH=remotelymatch/openai-api-key
# Azure Key Vault (optional alternative):
# SECRETS_PROVIDER=azure-key-vault
# AZURE_KEY_VAULT_URL=https://<your-vault-name>.vault.azure.net/
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
AGENT_HOME=/Users/user/job-event-agent
APP_NAME=remotelymatch
VITE_APP_NAME=remotelymatch
VITE_APP_URL=http://localhost:5173
RENDER_URL=https://remotematch.onrender.com

# Email — team@remotelymatch.app via Google Workspace (send) + Resend fallback
# 1) workspace.google.com → add remotelymatch.app → create mailbox team@
# 2) Security → 2-Step Verification → App passwords → Mail
TEAM_EMAIL=team@remotelymatch.app
GMAIL_SMTP_USER=team@remotelymatch.app
GMAIL_SMTP_PASS=
# Hunter.io + Apollo — verified recruiter emails (optional)
# https://hunter.io/api-keys · https://app.apollo.io/#/settings/integrations/api
HUNTER_API_KEY=
APOLLO_API_KEY=
# Or use Cloudflare Email Routing for other addresses (not team@ if Workspace owns it)
# Resend fallback — domain remotelymatch.app must stay verified in Resend
RESEND_API_KEY=
# Production sender (matches TEAM_EMAIL)
# EMAIL_FROM=remotelymatch <team@remotelymatch.app>
# Dev sandbox only:
EMAIL_FROM=remotelymatch <onboarding@resend.dev>

# Open job market — all remote roles for any resume (set OPEN_JOB_MARKET=0 for legacy DevOps-only mode)
OPEN_JOB_MARKET=1

# Job ingestion — omit JOB_SOURCES_ENABLED to search ALL live boards (remoteok, greenhouse, adzuna, …)
# JOB_SOURCES_ENABLED=remoteok,greenhouse,adzuna
JOB_GREENHOUSE_BOARDS=anthropic,datadog,cloudflare,gitlab,mongodb,elastic,databricks,coinbase,fastly,reddit,grafanalabs,pinterest,okta,pagerduty,newrelic,twilio
JOB_LEVER_BOARDS=palantir,spotify
JOB_ASHBY_BOARDS=snowflake,openai,notion,ramp,linear,deel,supabase,cognition
JOB_JUNGLE_PAGES=5
JOB_ROBERTHALF_PAGES=8
JOB_ARBEITNOW_PAGES=3
JOB_FOURDAYWEEK_PAGES=3
DICE_SEARCH_KEYWORD=remote
# INDEED_RSS_URL=
# INDEED_SEARCH_QUERY=devops engineer remote
# Adzuna job API — https://developer.adzuna.com (register → API keys)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_WHAT=devops engineer remote
ADZUNA_WHERE=remote
ADZUNA_MAX_DAYS_OLD=7
USAJOBS_API_KEY=
USAJOBS_USER_EMAIL=
USAJOBS_KEYWORD=remote
