PORT=5100
NODE_ENV=development
MONGODB_URI=
# With Docker Compose Mongo (npm run mongo:up) — port 27018 if 27017 is taken:
# MONGODB_URI=mongodb://127.0.0.1:27018/remotelymatch
# Or use an existing local Mongo on 27017:
# MONGODB_URI=mongodb://127.0.0.1:27017/remotelymatch
JWT_ACCESS_SECRET=change_this_to_a_long_random_value
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional secrets provider (recommended for production — open source)
# SECRETS_PROVIDER=hashicorp-vault
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=
# VAULT_MOUNT=secret
# VAULT_SECRET_PATH=remotelymatch
# Populate Vault: ./scripts/push-secrets-to-vault.sh
# Enable on Render: ./scripts/configure-hashicorp-vault-render.sh
# Store all keys in one KV object at secret/data/remotelymatch (OPENAI_API_KEY, APOLLO_API_KEY, …)
# Or use per-key paths: VAULT_OPENAI_API_KEY_PATH=remotelymatch/openai-api-key
# Azure Key Vault (optional alternative):
# SECRETS_PROVIDER=azure-key-vault
# AZURE_KEY_VAULT_URL=https://<your-vault-name>.vault.azure.net/
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
AGENT_HOME=/Users/user/job-event-agent
APP_NAME=remotelymatch
VITE_APP_NAME=remotelymatch
VITE_APP_URL=http://localhost:5173
RENDER_URL=https://remotematch.onrender.com

# Email — team@remotelymatch.app via Google Workspace (send) + Resend fallback
# 1) workspace.google.com → add remotelymatch.app → create mailbox team@
# 2) Security → 2-Step Verification → App passwords → Mail
TEAM_EMAIL=team@remotelymatch.app
GMAIL_SMTP_USER=team@remotelymatch.app
GMAIL_SMTP_PASS=
# Hunter.io + Apollo — verified recruiter emails (optional)
# https://hunter.io/api-keys · https://app.apollo.io/#/settings/integrations/api
HUNTER_API_KEY=
APOLLO_API_KEY=
# Or use Cloudflare Email Routing for other addresses (not team@ if Workspace owns it)
# Resend fallback — domain remotelymatch.app must stay verified in Resend
RESEND_API_KEY=
# Production sender (matches TEAM_EMAIL)
# EMAIL_FROM=remotelymatch <team@remotelymatch.app>
# Dev sandbox only:
EMAIL_FROM=remotelymatch <onboarding@resend.dev>

# Open job market — all remote roles for any resume (set OPEN_JOB_MARKET=0 for legacy DevOps-only mode)
OPEN_JOB_MARKET=1
# Block UK/EU-only jobs from matches and ingest (set US_REMOTE_JOBS_ONLY=0 to allow international)
US_REMOTE_JOBS_ONLY=1
# Minimum listed compensation (USD). Jobs below this are dropped; no-salary ATS roles still allowed.
JOB_MIN_SALARY_USD=140000
# Minimum recruiter callback score (0-95) — quality over volume
JOB_MIN_CALLBACK_SCORE=25
QUALITY_FIRST_MODE=1
# Drop jobs older than this from ingest, user pool, and nightly Mongo purge
JOB_MAX_AGE_DAYS=30
# Aggregators (Adzuna) must link to a direct employer ATS apply page
JOB_AGGREGATOR_REQUIRES_ATS=1
# Reject jobs where company name does not match apply URL / ATS board slug
JOB_REQUIRE_DOMAIN_MATCH=1
# Hide jobs above this applicant count when known (LinkedIn/Indeed/extension)
JOB_MAX_APPLICANTS=75
# Penalize companies with more than this many similar open roles in the pool
JOB_MAX_SAME_COMPANY_ROLES=5
# Set JOB_DROP_LOW_YIELD_SOURCES=1 to hard-hide sources with <4% reply rate after 8+ attempts
# Tailoring speed: 1 = one quick refine pass on generate (default); 0 = single AI call only
TAILOR_GENERATE_MAX_PASSES=1
TAILOR_POLISH_MAX_PASSES=6
TAILOR_DEFAULT_PAGES=4
TAILOR_ATS_TARGET_MIN=90

# Job ingestion — defaults to actionable US sources only (ATS + curated remote boards)
# Optional extras (not recommended): jobicy,himalayas,dice,indeed,ycombinator
JOB_SOURCES_ENABLED=remoteok,remotive,weworkremotely,jobspresso,greenhouse,lever,ashby,adzuna
JOB_GREENHOUSE_BOARDS=anthropic,stripe,figma,datadog,cloudflare,gitlab,mongodb,elastic,databricks,coinbase,robinhood,block,dropbox,asana,lyft,instacart,scaleai,vercel,roblox,affirm,purestorage,fastly,reddit,grafanalabs,pinterest,okta,pagerduty,newrelic,twilio
JOB_LEVER_BOARDS=palantir,spotify,binance
JOB_ASHBY_BOARDS=snowflake,openai,notion,ramp,linear,deel,supabase,cognition,vanta,plaid,harvey,cursor,perplexity,cerebras
JOB_JUNGLE_PAGES=5
JOB_ROBERTHALF_PAGES=8
JOB_ARBEITNOW_PAGES=3
JOB_FOURDAYWEEK_PAGES=3
DICE_SEARCH_KEYWORD=remote
# INDEED_RSS_URL=
# INDEED_SEARCH_QUERY=devops engineer remote
# Adzuna job API — https://developer.adzuna.com (register → API keys)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_WHAT=remote software engineer
ADZUNA_QUERIES=remote software engineer,remote devops engineer,remote project manager,remote product manager,remote data engineer
ADZUNA_WHERE=United States
ADZUNA_MAX_DAYS_OLD=7
USAJOBS_API_KEY=
USAJOBS_USER_EMAIL=
USAJOBS_KEYWORD=remote
