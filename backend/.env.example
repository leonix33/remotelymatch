PORT=5100
NODE_ENV=development
MONGODB_URI=
# With Docker Compose Mongo (npm run mongo:up) — port 27018 if 27017 is taken:
# MONGODB_URI=mongodb://127.0.0.1:27018/remotematch
# Or use an existing local Mongo on 27017:
# MONGODB_URI=mongodb://127.0.0.1:27017/remotematch
JWT_ACCESS_SECRET=change_this_to_a_long_random_value
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
OPENAI_API_KEY=
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
AGENT_HOME=/Users/user/job-event-agent
APP_NAME=RemoteMatch
VITE_APP_NAME=RemoteMatch
VITE_APP_URL=http://localhost:5173
RENDER_URL=https://remotematch.onrender.com
